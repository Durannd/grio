# Configurações do Banco de Dados
DATABASE_URL=postgresql://user:password@db:5432/studydb
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Configurações de IA (Gemini)
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Configurações de Segurança (SECRET_KEY deve ter pelo menos 64 caracteres)
# Gerar com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=generate_a_strong_secret_key_with_at_least_64_characters_for_production_use
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

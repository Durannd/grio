# ===========================
# Griô — .gitignore
# Stack: SvelteKit + Python/FastAPI + Neo4j + PostgreSQL + Docker
# ===========================

# ---------------------
# Dependências
# ---------------------
node_modules/
.pnp/
.pnp.js

# ---------------------
# Python
# ---------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt
.venv/
venv/
env/
ENV/

# ---------------------
# SvelteKit / Vite
# ---------------------
.svelte-kit/
/build
/dist

# ---------------------
# Variáveis de ambiente (NUNCA subir)
# ---------------------
.env
.env.*
!.env.example

# ---------------------
# Docker (volumes locais)
# ---------------------
postgres_data/
neo4j_data/
neo4j_logs/

# ---------------------
# IDE / Editor
# ---------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ---------------------
# OS
# ---------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---------------------
# Logs
# ---------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------
# Testes e Cobertura
# ---------------------
coverage/
.coverage
htmlcov/
.pytest_cache/
.nyc_output/

# ---------------------
# Misc
# ---------------------
*.bak
*.tmp
*.temp
.cache/
.openclaude/
.claude/
.agent
